<UserControl x:Class="DiagramApp.MainControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DiagramApp" 
             xmlns:conv="clr-namespace:DiagramApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:BoolToExpandIconConverter x:Key="BoolToExpandIcon" />
    </UserControl.Resources>
    
    <Grid HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Верхняя панель с датами, фильтром и кнопкой -->
        <Border Grid.Row="0"
        Margin="10"
        Padding="10"
        Background="#F0F0F0"
        CornerRadius="5">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <!-- Начальная дата -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0" MaxHeight="30">
                        <TextBlock Text="Начальная дата:" 
                           Foreground="Blue"
                           VerticalAlignment="Center"
                           Margin="0,0,5,0"/>
                        <DatePicker x:Name="StartDatePicker" Width="120"/>
                    </StackPanel>

                    <!-- Конечная дата -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0"  MaxHeight="30">
                        <TextBlock Text="Конечная дата:" 
                           Foreground="Blue"
                           VerticalAlignment="Center"
                           Margin="0,0,5,0"/>
                        <DatePicker x:Name="EndDatePicker" Width="120"/>
                    </StackPanel>

                    <!-- Раскрывающийся фильтр по сотрудникам -->
                    <Expander Header="Фильтр по сотрудникам" 
                      IsExpanded="False"
                      Margin="0,0,20,0"
                      VerticalAlignment="Center">
                        <StackPanel Margin="0,10,0,0">
                            <ListBox x:Name="PersonsListBox" 
                             ItemsSource="{Binding ListPersons}"
                             SelectionMode="Multiple"
                             Height="150"
                             Width="200"
                             SelectionChanged="PersonsListBox_SelectionChanged"
                             Margin="0,0,0,10"/>
                            <Button x:Name="ClearSelectionButton"
                            Content="Снять выделение" 
                            Click="ClearSelectionButton_Click"
                            Padding="10,5"
                            Margin="5"
                            HorizontalAlignment="Center"
                            Width="120"/>
                        </StackPanel>
                    </Expander>

                    <!-- Кнопка поиска -->
                    <Button x:Name="BuildButton"
                    Width="150"
                    Height="30"
                    Background="#007ACC"
                    Click="BuildButton_Click"
                    Content="Сформировать отчет"
                    Cursor="Hand"
                    Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Индикаторы цвета -->
        <Border
         Grid.Row="1"
         Margin="10,5"
         Padding="10,5"
         Background="#F9F9F9"
         BorderBrush="#E0E0E0"
         BorderThickness="1"
         CornerRadius="3">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Синий - Назначена -->
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <Rectangle Width="20" Height="20" Fill="#6495ED" Margin="0,0,5,0" RadiusX="3" RadiusY="3" />
                    <TextBlock Text="Назначена" VerticalAlignment="Center" FontSize="12" />
                </StackPanel>

                <!-- Желтый - Исполняется (в срок) -->
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <Rectangle Width="20" Height="20" Fill="#FFDC64" Margin="0,0,5,0" RadiusX="3" RadiusY="3" />
                    <TextBlock Text="Исполняется" VerticalAlignment="Center" FontSize="12" />
                </StackPanel>

                <!-- Красный - Просрочено -->
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <Rectangle Width="20" Height="20" Fill="#FF6464" Margin="0,0,5,0" RadiusX="3" RadiusY="3" />
                    <TextBlock Text="Просрочено" VerticalAlignment="Center" FontSize="12" />
                </StackPanel>

                <!-- Зеленый - Выполнена в срок -->
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <Rectangle Width="20" Height="20" Fill="#90EE90" Margin="0,0,5,0" RadiusX="3" RadiusY="3" />
                    <TextBlock Text="Выполнена в срок" VerticalAlignment="Center" FontSize="12" />
                </StackPanel>

                <!-- Ярко-зеленый - Завершена -->
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <Rectangle Width="20" Height="20" Fill="#4CAF50" Margin="0,0,5,0" RadiusX="3" RadiusY="3" />
                    <TextBlock Text="Завершена" VerticalAlignment="Center" FontSize="12" />
                </StackPanel>

                <!-- Оранжевый - Пауза -->
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <Rectangle Width="20" Height="20" Fill="#FFA500" Margin="0,0,5,0" RadiusX="3" RadiusY="3" />
                    <TextBlock Text="Пауза" VerticalAlignment="Center" FontSize="12" />
                </StackPanel>

                <!-- Серый - Отменена -->
                <StackPanel Orientation="Horizontal">
                    <Rectangle Width="20" Height="20" Fill="#696969" Margin="0,0,5,0" RadiusX="3" RadiusY="3" />
                    <TextBlock Text="Отменена" VerticalAlignment="Center" FontSize="12" />
                </StackPanel>

                <!-- Черный - Фактический план -->
                <StackPanel Orientation="Horizontal">
                    <Rectangle Width="40" Height="4" Fill="Black" Margin="10,0,5,0" />
                    <TextBlock Text="Факт. длительность" VerticalAlignment="Center" FontSize="12" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="10,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Заголовок левой панели -->
            <Border Grid.Column="0" Height="Auto" Background="#E8E8E8"
                    BorderBrush="#CCCCCC" BorderThickness="0,0,1,1">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="12" FontWeight="Bold" Foreground="Black"
                           Text="Сотрудник / Задача" />
            </Border>

            <!-- Заголовок правой панели с датами -->
            <ScrollViewer Grid.Column="1" x:Name="DateHeaderScrollViewer"
                          HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalAlignment="Left"
                          ScrollChanged="DateHeaderScrollViewer_ScrollChanged">
                <Border Background="#E8E8E8" BorderBrush="#CCCCCC" BorderThickness="1,0,0,1">
                    <Canvas x:Name="DateHeaderCanvas" Height="50" Background="#E8E8E8" />
                </Border>
            </ScrollViewer>
        </Grid>
        
        <Grid Grid.Row="3" Margin="10,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
          
            <!-- Левая колонка с группировкой -->
            <ScrollViewer Grid.Column="0" x:Name="LeftScrollViewer"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Hidden"
                          ScrollChanged="LeftScrollViewer_ScrollChanged">
                <ItemsControl x:Name="PersonNamesPanel" 
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Top">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Группа сотрудника -->
                            <Border BorderBrush="#E0E0E0">
                                <StackPanel>
                                    <!-- Заголовок сотрудника с кнопкой сворачивания -->
                                    <Border Background="#50C8C8C8" 
                                            Cursor="Hand"
                                            MouseLeftButtonDown="PersonHeader_Click"
                                            Tag="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Кнопка сворачивания/разворачивания -->
                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding IsExpanded, Converter={StaticResource BoolToExpandIcon}}"
                                                       FontSize="14" 
                                                       FontWeight="Bold"
                                                       Margin="5"
                                                       Width="20"
                                                       HorizontalAlignment="Center"/>

                                            <!-- Имя сотрудника -->
                                            <TextBlock Grid.Column="1"
                                                       Margin="0,5"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Text="{Binding PersonName}" />
                                        </Grid>
                                    </Border>

                                    <!-- Список задач (видим только если развернуто) отступы -->
                                    <ItemsControl ItemsSource="{Binding Tasks}" 
                                                  Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Height="Auto"
                                                        MinHeight="30"
                                                        Padding="25,5,5,5"
                                                        Background="Transparent"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="TaskName_Click"
                                                        Tag="{Binding}">
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding TaskName}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Правая колонка с диаграммой -->
            <ScrollViewer Grid.Column="1" 
                          x:Name="GanttScrollViewer"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Hidden"
                          ScrollChanged="GanttScrollViewer_ScrollChanged">
                <Canvas x:Name="GanttCanvas" 
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="#FEFEFE" />
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>