<UserControl x:Class="DiagramApp.MainControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DiagramApp"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <!-- Title="Диаграмма Ганта"  WindowStartupLocation="CenterScreen" -->
    <Grid HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Панель выбора дат -->
        <Border
         Grid.Row="0"
         Margin="10"
         Padding="10"
         Background="#F0F0F0"
         CornerRadius="5">
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <StackPanel Margin="0,0,20,0" Orientation="Horizontal">
                    <TextBlock
                     Margin="0,0,5,0"
                     VerticalAlignment="Center"
                     Text="Начальная дата:" />
                    <DatePicker x:Name="StartDatePicker" Width="120" />
                </StackPanel>

                <StackPanel Margin="0,0,20,0" Orientation="Horizontal">
                    <TextBlock
                     Margin="0,0,5,0"
                     VerticalAlignment="Center"
                     Text="Конечная дата:" />
                    <DatePicker x:Name="EndDatePicker" Width="120" />
                </StackPanel>

                <Button
                 x:Name="BuildButton"
                 Width="150"
                 Height="30"
                 Background="#007ACC"
                 Click="BuildButton_Click"
                 Content="Создать диаграмму"
                 Cursor="Hand"
                 Foreground="White" />
            </StackPanel>
        </Border>

        <!-- Индикаторы цвета -->
        <Border
         Grid.Row="1"
         Margin="10,5"
         Padding="10,5"
         Background="#F9F9F9"
         BorderBrush="#E0E0E0"
         BorderThickness="1"
         CornerRadius="3">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Синий - Назначена -->
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <Rectangle Width="20" Height="20" Fill="#6495ED" Margin="0,0,5,0" RadiusX="3" RadiusY="3" />
                    <TextBlock Text="Назначена" VerticalAlignment="Center" FontSize="11" />
                </StackPanel>

                <!-- Желтый - Исполняется (в срок) -->
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <Rectangle Width="20" Height="20" Fill="#FFDC64" Margin="0,0,5,0" RadiusX="3" RadiusY="3" />
                    <TextBlock Text="Исполняется" VerticalAlignment="Center" FontSize="11" />
                </StackPanel>

                <!-- Красный - Просрочено -->
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <Rectangle Width="20" Height="20" Fill="#FF6464" Margin="0,0,5,0" RadiusX="3" RadiusY="3" />
                    <TextBlock Text="Просрочено" VerticalAlignment="Center" FontSize="11" />
                </StackPanel>

                <!-- Зеленый - Выполнена в срок -->
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <Rectangle Width="20" Height="20" Fill="#90EE90" Margin="0,0,5,0" RadiusX="3" RadiusY="3" />
                    <TextBlock Text="Выполнена в срок" VerticalAlignment="Center" FontSize="11" />
                </StackPanel>

                <!-- Ярко-зеленый - Завершена -->
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <Rectangle Width="20" Height="20" Fill="#4CAF50" Margin="0,0,5,0" RadiusX="3" RadiusY="3" />
                    <TextBlock Text="Завершена" VerticalAlignment="Center" FontSize="11" />
                </StackPanel>

                <!-- Оранжевый - Пауза -->
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <Rectangle Width="20" Height="20" Fill="#FFA500" Margin="0,0,5,0" RadiusX="3" RadiusY="3" />
                    <TextBlock Text="Пауза" VerticalAlignment="Center" FontSize="11" />
                </StackPanel>

                <!-- Серый - Отменена -->
                <StackPanel Orientation="Horizontal">
                    <Rectangle Width="20" Height="20" Fill="#696969" Margin="0,0,5,0" RadiusX="3" RadiusY="3" />
                    <TextBlock Text="Отменена" VerticalAlignment="Center" FontSize="11" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Фиксированные заголовки -->
        <Grid Grid.Row="2" Margin="10,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Заголовок левой панели -->
            <Border
             Grid.Column="0"
             Height="Auto"
             Background="#E8E8E8"
             BorderBrush="#CCCCCC"
             BorderThickness="0,0,1,1">
                <TextBlock
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 FontSize="12"
                 FontWeight="Bold"
                 Foreground="Black"
                 Text="Сотрудник / Задача" />
            </Border>

            <!-- Заголовок правой панели с датами -->
            <ScrollViewer
             Grid.Column="1"
             x:Name="DateHeaderScrollViewer"
             HorizontalScrollBarVisibility="Auto"
             VerticalScrollBarVisibility="Disabled"
             HorizontalAlignment="Left"
             ScrollChanged="DateHeaderScrollViewer_ScrollChanged">
                <Border
                 Background="#E8E8E8"
                 BorderBrush="#CCCCCC"
                 BorderThickness="1,0,0,1">
                    <!-- Убираем HorizontalAlignment и используем только Canvas -->
                    <Canvas x:Name="DateHeaderCanvas" 
                         Height="50"
                         Background="#E8E8E8" />
                </Border>
            </ScrollViewer>
        </Grid>

        <!-- Данные - используем Grid с независимыми скроллами -->
        <Grid Grid.Row="3" Margin="10,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Левая колонка с именами (только вертикальный скролл) -->
            <ScrollViewer
             Grid.Column="0"
             x:Name="LeftScrollViewer"
             HorizontalScrollBarVisibility="Disabled"
             VerticalScrollBarVisibility="Hidden"
             ScrollChanged="LeftScrollViewer_ScrollChanged">
                <ItemsControl x:Name="PersonNamesPanel" 
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Top">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock
                                     Margin="0,0,0,5"
                                     Padding="5"
                                     Background="#50C8C8C8"
                                     FontSize="14"
                                     FontWeight="Bold"
                                     Text="{Binding PersonName}" />
                                    <ItemsControl ItemsSource="{Binding Tasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                 Height="30"
                                                 Margin="0,1,0,1"
                                                 Padding="10,0,0,0">
                                                    <TextBlock
                                                     VerticalAlignment="Center"
                                                     FontSize="11"
                                                     Text="{Binding TaskName}"
                                                     TextTrimming="CharacterEllipsis" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Правая колонка с диаграммой (вертикальный + горизонтальный скролл) -->
            <ScrollViewer
             Grid.Column="1"
             x:Name="GanttScrollViewer"
             HorizontalScrollBarVisibility="Hidden"
             VerticalScrollBarVisibility="Hidden"
             ScrollChanged="GanttScrollViewer_ScrollChanged">
                <Canvas x:Name="GanttCanvas" 
                     HorizontalAlignment ="Left"
                     VerticalAlignment ="Top"
                     Background="#FEFEFE" />
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>